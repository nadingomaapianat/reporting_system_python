# =============================================================================
# reporting_system_python — copy values into .env or environment.env
# Never commit real .env with secrets.
# =============================================================================

# --- Node (reporting_system_node) ---
NODE_API_URL=https://grc-reporting-node-uat.adib.co.eg
NODE_BACKEND_URL=https://grc-reporting-node-uat.adib.co.eg

# --- This service (Python) public URL (browser CORS + links) ---
PYTHON_API_URL=https://grc-reporting-py-uat.adib.co.eg
PYTHON_API_BASE=https://grc-reporting-py-uat.adib.co.eg

# --- CORS (browser direct calls with credentials) — list every frontend origin ---
CORS_ORIGINS=https://grc-reporting-uat.adib.co.eg,https://grc-dcc-uat.adib.co.eg,https://grc-reporting-node-uat.adib.co.eg
FRONTEND_ORIGIN=https://grc-reporting-uat.adib.co.eg

# --- JWT (must match reporting_system_node JWT_SECRET) ---
JWT_SECRET=GRC_ADIB_2025

# --- Admin / function scoping (same rules as Node UserFunctionAccessService.isAdmin) ---
# Optional: comma-separated user IDs that see all functions (like Node REPORTING_SUPER_ADMIN_USER_IDS).
# REPORTING_SUPER_ADMIN_USER_IDS=

# --- CSRF ---
CSRF_COOKIE_SECURE=true
# Optional: lax | strict | none (none requires CSRF_COOKIE_SECURE=true)
# CSRF_COOKIE_SAMESITE=lax

# --- Misc ---
API_TIMEOUT=60
TRUST_PROXY=true
CERT_PATH=./certs.pem
NODE_ENV=production

# TLS for outbound HTTPS from Python
VERIFY_SSL=true

# --- Optional debug (disable in production) ---
# REPORTING_LOG_AUTH_HEADERS=true
# REPORTING_DEBUG_COOKIES_ENDPOINT=true

# --- Optional integrations ---
# OCR_WEBHOOK_URL=https://n8nio.pianat.ai/webhook/ocr-check

# --- Database (see also DB_HOST / DB_SERVER, DB_CONNECT_TIMEOUT, etc.) ---
DB_CONNECT_TIMEOUT=10
