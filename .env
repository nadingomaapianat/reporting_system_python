# Backend API Configuration
# Set this to your Node.js backend URLt.ai

NODE_BACKEND_URL=http://10.240.53.65:3002

# API Configuration
NODE_API_URL=http://10.240.53.65:3002
PYTHON_API_URL=http://10.240.53.65:8000
API_TIMEOUT=60

# Database Configuration (use DB_HOST or DB_SERVER)
# Windows Authentication: domain\user + password (NTLM); or Trusted_Connection with DB_BACKEND=odbc
DB_SERVER=10.240.10.202
DB_PORT=5555
DB_NAME=NEWDCC-V4-UAT
DB_DRIVER=ODBC Driver 18 for SQL Server

# Windows Authentication Settings
# Set DB_USE_WINDOWS_AUTH=yes to use Windows Authentication (current user)
# Set DB_USE_WINDOWS_AUTH=yes to use SQL Server Authentication (UID/PWD)
DB_USE_WINDOWS_AUTH=yes

# For Windows Authentication with domain credentials (if needed)
# Leave empty to use current Windows user, or specify domain\username
DB_DOMAIN=ADIBEG
DB_USERNAME=GRCSVC
DB_PASSWORD=P@ssw0rd

# Connection Settings
DB_ENCRYPT=yes
DB_TRUST_SERVER_CERTIFICATE=yes
DB_REQUEST_TIMEOUT=60000
# Python: timeout in seconds (fail fast when DB unreachable; default 10 to avoid 504)
DB_CONNECT_TIMEOUT=10

# Connection Pool Settings (similar to NestJS)
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=60000
DB_POOL_IDLE=30000

NODE_ENV=production
CORS_ORIGINS=https://grc-reporting-uat.adib.co.eg,https://grc-dcc-uat.adib.co.eg,https://grc-reporting-node-uat.adib.co.eg
FRONTEND_ORIGIN=https://grc-reporting-uat.adib.co.eg
CSRF_COOKIE_SECURE=true
TRUST_PROXY=true
CERT_PATH=./certs.pem

# TLS: true = verify certs (production), false = skip verification (e.g. self-signed / dev)
VERIFY_SSL=true

# JWT: must match Node (reporting-system-node) JWT_SECRET so the same token works for both. Required for /api/grc/* export.
# For export without frontend change: Node must set COOKIE_DOMAIN (e.g. .adib.co.eg) so the browser sends the cookie to this API.
JWT_SECRET=GRC_ADIB_2025

# Debug auth/cookies during migration (disable after validation).
REPORTING_LOG_AUTH_HEADERS=true
REPORTING_DEBUG_COOKIES_ENDPOINT=true

# --- Optional: same as Node — user IDs that bypass function filter (comma-separated). Uncomment to use.
# REPORTING_SUPER_ADMIN_USER_IDS=

# --- Optional: CSRF cookie SameSite (lax|strict|none). none requires CSRF_COOKIE_SECURE=true.
# CSRF_COOKIE_SAMESITE=lax

# --- Optional: public base alias (same as PYTHON_API_URL if unset; used by some scripts)
# PYTHON_API_BASE=http://10.240.53.65:8000

# --- Optional: OCR / n8n webhook (if bank check uses it)
# OCR_WEBHOOK_URL=https://n8nio.pianat.ai/webhook/ocr-check
