# Reporting Python – links and API bases (copy to .env or use this file)
# Node backend URL (reporting_system_node)
NODE_API_URL=https://reporting-madinetmasr-system-backend.comply.now
NODE_BACKEND_URL=https://reporting-madinetmasr-system-backend.comply.now

# This service (Python) base URL – used when Python calls itself or is referenced
PYTHON_API_URL=https://reporting-madinetmasr-system-python.comply.now
PYTHON_API_BASE=https://reporting-madinetmasr-system-python.comply.now

# CORS: comma-separated origins allowed to call this API (or set FRONTEND_ORIGIN for single)
CORS_ORIGINS=https://reporting-madinetmasr-system-frontend.comply.now,https://reporting-madinetmasr-system-python.comply.now
FRONTEND_ORIGIN=https://reporting-madinetmasr-system-frontend.comply.now

# OCR webhook (e.g. n8n) for bank check
OCR_WEBHOOK_URL=https://n8nio.pianat.ai/webhook/ocr-check

# API timeout (seconds)
API_TIMEOUT=60

# Main GRC backend URL (for token+CSRF export data; default from NODE_API_URL if not set)
# GRC_BACKEND_URL=https://backend-madinetmasr-compliance.comply.now

# Optional: PORT=8000, RELOAD=1, CSRF_COOKIE_SECURE=false

# Database – set in .env to match the reporting node (same DB_HOST/DB_SERVER, DB_PORT, DB_NAME, etc.).
# Values here are fallbacks for local dev only; .env is loaded after this file so .env wins.
# SQL Server auth: DB_USE_WINDOWS_AUTH=0, use DB_USERNAME + DB_PASSWORD only (no domain).
DB_BACKEND=pymssql
DB_HOST=206.189.57.0
DB_SERVER=206.189.57.0
DB_PORT=1433
DB_NAME=GRCDB
DB_USE_WINDOWS_AUTH=0
# DB_DOMAIN=ADIBEG
DB_USERNAME=SA
DB_PASSWORD=Nothing_159
DB_DRIVER=ODBC Driver 18 for SQL Server
# Connection timeout (seconds); fail fast when DB unreachable to avoid 504
DB_CONNECT_TIMEOUT=10
